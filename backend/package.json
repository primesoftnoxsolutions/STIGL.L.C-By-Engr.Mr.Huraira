{
  "name": "cylinder-erp-backend",
  "version": "1.0.0",
  "description": "Backend API for Cylinder Management ERP",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "prestart": "node scripts/ensureDefaultAdminReady.js",
    "dev": "nodemon server.js",
    "predev": "node scripts/ensureDefaultAdminReady.js",
    "db:setup": "node scratch/setup-db.js",
    "db:ensure-admin": "node scripts/ensureDefaultAdminReady.js",
    "seed": "node scripts/seedDatabase.js",
    "create-admin": "node scripts/createSuperAdmin.js",
    "migrate:manager-role": "node migrations/replaceAdminWithManagerRole.js",
    "migrate:quotation-walk-in": "node migrations/addQuotationWalkInCustomer.js",
    "migrate:maintenance": "node migrations/addMaintenanceTables.js",
    "migrate:expenses": "node migrations/addExpensesTable.js",
    "mongo:clear": "node scripts/mongoClear.js",
    "mongo:reset:test": "node scripts/mongoResetForTest.js"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.19.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
